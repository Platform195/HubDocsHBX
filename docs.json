{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "HBX Self Serve",
  "description": "Promote your hotel across the HBX Group B2B network — guides for the self-serve advertising portal.",
  "colors": {
    "primary": "#479AA3",
    "light": "#D10070",
    "dark": "#0077A3"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://hbx-docs.uplifthub.io/"
  },
  "fonts": {
    "family": "Geist"
  },
  "appearance": {
    "default": "light"
  },
  "navbar": {
    "links": [
      { "label": "Support", "href": "mailto:support@uplifthub.io" }
    ],
    "primary": {
      "type": "button",
      "label": "Open the portal",
      "href": "https://app.uplifthub.io/HBX-self-serve/"
    }
  },
  "footer": {
    "socials": {
      "website": "https://www.hbxgroup.com"
    },
    "links": [
      {
        "header": "Legal",
        "items": [
          {
            "label": "Terms & Conditions",
            "href": "https://hbx-docs.uplifthub.io/legal/terms-and-conditions"
          },
          {
            "label": "Platform Terms of Use",
            "href": "https://hbx-docs.uplifthub.io/legal/platform-terms"
          },
          {
            "label": "Privacy Policy",
            "href": "https://hbx-docs.uplifthub.io/legal/privacy-policy"
          }
        ]
      }
    ]
  },
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "get-started/introduction",
          "get-started/creating-an-account",
          "get-started/navigating"
        ]
      },
      {
        "group": "Packages",
        "pages": [
          "packages/choosing-a-package",
          "packages/ad-formats",
          "packages/add-ons"
        ]
      },
      {
        "group": "Creating a campaign",
        "pages": [
          "campaigns/create-campaign",
          "campaigns/select-package",
          "campaigns/select-hotel",
          "campaigns/customisation",
          "campaigns/campaign-details",
          "campaigns/summary"
        ]
      },
      {
        "group": "Checkout",
        "pages": [
          "checkout/shopping-cart",
          "checkout/checkout"
        ]
      },
      {
        "group": "Managing your account",
        "pages": [
          "managing/dashboard",
          "managing/campaigns",
          "managing/hotels",
          "managing/purchases"
        ]
      },
      {
        "group": "Help",
        "pages": [
          "reference/glossary",
          "reference/support"
        ]
      },
      {
        "group": "Legal",
        "pages": [
          "legal/terms-and-conditions",
          "legal/platform-terms",
          "legal/privacy-policy"
        ]
      }
    ]
  },
  "search": {
    "prompt": "Search the docs…"
  },
  "seo": {
    "metatags": {
      "og:site_name": "HBX Self Serve Docs",
      "og:title": "HBX Self Serve Documentation",
      "og:description": "Guides for promoting your hotel across the HBX Group B2B network using the self-serve advertising portal."
    },
    "indexing": "all"
  }
}
